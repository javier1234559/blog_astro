NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Trigger GitHub sync workflow via GET /api/trigger
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=javier1234559/blog_astro

# YouTube Music page (/music)
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_FAVORITES_PLAYLIST_ID=PLxxxxxxxx
# Option A: all public playlists from channel
YOUTUBE_CHANNEL_ID=UCxxxxxxxx
# Option B: specific playlists (comma-separated, overrides channel list)
# YOUTUBE_PLAYLIST_IDS=PLxxxx,PLyyyy

# Discord Webhook
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: Slack Webhook
# SLACK_WEBHOOK=https://hooks.slack.com/services/your_slack_webhook_url_here

# Optional: Google Chat Webhook
# GOOGLE_CHAT_WEBHOOK=https://chat.googleapis.com/v1/spaces/your_google_chat_webhook_url_here

# Optional: Microsoft Teams Webhook
# MS_TEAMS_WEBHOOK=https://outlook.office.com/webhook/your_ms_teams_webhook_url_here

