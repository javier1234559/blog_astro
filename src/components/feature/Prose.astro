<article
  class="prose dark:prose-invert
  prose-h1:font-barlow prose-h1:font-bold prose-h2:mt-2
  prose-a:text-blue-600 prose-p:text-justify prose-img:rounded-xl
  prose-pre:!p-4 prose-pre:!rounded-lg prose-pre:relative
  container text-left w-full max-w-none">
  <slot />
</article>


<style is:global>
  .prose > pre {
    position: relative;
  }

  .prose > pre > copy-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
  }

  .prose :not(pre) > code {
    padding: 0.125rem 0.375rem;
    color: var(--code-text);
    background-color: var(--code-background);
    border: 1px solid var(--code-border);
    border-radius: 0.25rem;
    font-size: 0.9em;
    font-weight: 500;
    white-space: break-spaces;
  }

  .prose :not(pre) > code::before,
  .prose :not(pre) > code::after {
    content: none;
  }

  .prose strong :not(pre) > code,
  .prose strong > code {
    font-weight: 700;
  }

  .prose .youtube-embed {
    margin: 2rem 0;
  }

  .prose .youtube-embed__iframe {
    width: 100%;
    max-width: 560px;
    aspect-ratio: 16 / 9;
    border: 0;
    border-radius: 0.75rem;
  }
</style>

